<div class="relative min-h-screen flex flex-col">
  <div class="max-w-7xl mx-auto w-full px-4 md:px-6 lg:px-8">
    <div class="p-6 pb-28 md:pt-8 md:pb-8">

      <!-- Header -->
      <header class="flex items-center justify-between mb-8">
        <%= link_to :back, class: "text-text-secondary-light dark:text-text-secondary-dark hover:text-text-primary-light dark:hover:text-text-primary-dark" do %>
          <i class="fas fa-arrow-left text-xl"></i>
        <% end %>
        <h1 class="text-lg font-semibold text-text-primary-light dark:text-text-primary-dark">Team Detail</h1>
        <div class="w-6"></div>
      </header>

      <main>
        <!-- Team Profile -->
        <section class="flex items-center gap-4 mb-8">
          <% if @team.flag_url.present? %>
            <%= image_tag @team.flag_url, alt: @team.name, class: "w-20 h-20 rounded-full object-cover" %>
          <% else %>
            <div class="w-20 h-20 rounded-full bg-secondary/20 flex items-center justify-center">
              <span class="text-3xl font-bold text-secondary"><%= @team.name[0] %></span>
            </div>
          <% end %>
          <div>
            <h2 class="text-3xl font-bold text-text-primary-light dark:text-text-primary-dark"><%= @team.name %></h2>
            <div class="flex items-center gap-3 mt-1">
              <span class="text-2xl font-bold text-primary"><%= @team.points.to_i %> pts</span>
              <% if @team.progressed? %>
                <span class="px-2 py-1 rounded-full bg-accent-live/20 text-accent-live text-xs font-semibold flex items-center gap-1">
                  <i class="fas fa-check text-xs"></i> Advanced
                </span>
              <% else %>
                <span class="px-2 py-1 rounded-full bg-gray-500/20 text-gray-400 text-xs font-semibold flex items-center gap-1">
                  <i class="fas fa-minus text-xs"></i> In Group
                </span>
              <% end %>
            </div>
          </div>
        </section>

        <!-- Matches -->
        <section>
          <h3 class="text-lg font-semibold text-text-primary-light dark:text-text-primary-dark mb-3">Matches</h3>
          <% if @matches.empty? %>
            <p class="text-text-secondary-light dark:text-text-secondary-dark text-sm">No matches scheduled.</p>
          <% else %>
            <div class="space-y-3">
              <% @matches.each do |match| %>
                <% opponent = match.home_team_id == @team.id ? match.away_team : match.home_team %>
                <% result = match.result_for(@team) %>
                <% is_knockout = match.stage != 'Group Stage' %>
                <div class="bg-card-light dark:bg-card-dark rounded-2xl border border-border-light dark:border-border-dark p-4">
                  <!-- Stage & Date -->
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-xs font-semibold px-2 py-1 rounded-full <%= is_knockout ? 'bg-accent-live/20 text-accent-live' : 'bg-secondary/20 text-secondary' %>">
                      <%= match.stage %>
                    </span>
                    <span class="text-xs text-text-secondary-light dark:text-text-secondary-dark">
                      <%= match.start_time&.strftime("%-d %b %Y, %H:%M") %>
                    </span>
                  </div>

                  <!-- Teams & Score -->
                  <div class="flex items-center justify-between">
                    <!-- Home Team -->
                    <div class="flex flex-col items-center gap-1 w-24">
                      <% home = match.home_team %>
                      <% if home.flag_url.present? %>
                        <%= image_tag home.flag_url, alt: home.name, class: "h-10 w-10 rounded-full object-cover" %>
                      <% else %>
                        <div class="h-10 w-10 rounded-full bg-secondary/20 flex items-center justify-center">
                          <span class="text-sm font-bold text-secondary"><%= home.name[0] %></span>
                        </div>
                      <% end %>
                      <span class="text-xs font-semibold text-text-primary-light dark:text-text-primary-dark text-center leading-tight"><%= home.name %></span>
                    </div>

                    <!-- Score / Result -->
                    <div class="flex flex-col items-center gap-1">
                      <% if match.status == 'PostEvent' %>
                        <div class="text-2xl font-bold text-text-primary-light dark:text-text-primary-dark">
                          <%= match.home_score %> – <%= match.away_score %>
                        </div>
                        <span class="text-xs font-semibold px-2 py-0.5 rounded-full <%= result == 'Win' ? 'bg-green-500/20 text-green-400' : result == 'Lost' ? 'bg-red-500/20 text-red-400' : 'bg-gray-500/20 text-gray-400' %>">
                          <%= result %>
                        </span>
                      <% else %>
                        <div class="text-lg font-bold text-text-secondary-light dark:text-text-secondary-dark">vs</div>
                        <span class="text-xs text-text-secondary-light dark:text-text-secondary-dark">Upcoming</span>
                      <% end %>
                    </div>

                    <!-- Away Team -->
                    <div class="flex flex-col items-center gap-1 w-24">
                      <% away = match.away_team %>
                      <% if away.flag_url.present? %>
                        <%= image_tag away.flag_url, alt: away.name, class: "h-10 w-10 rounded-full object-cover" %>
                      <% else %>
                        <div class="h-10 w-10 rounded-full bg-secondary/20 flex items-center justify-center">
                          <span class="text-sm font-bold text-secondary"><%= away.name[0] %></span>
                        </div>
                      <% end %>
                      <span class="text-xs font-semibold text-text-primary-light dark:text-text-primary-dark text-center leading-tight"><%= away.name %></span>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </section>
      </main>

    </div>
  </div>
</div>

<%= render 'layouts/bottom_nav' %>
