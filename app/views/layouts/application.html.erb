<!DOCTYPE html>
<html lang="en">
  <head>
    <title>World Cup 2026</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Apply saved theme before paint to avoid flash -->
    <script>
      (function() {
        var mode = localStorage.getItem('darkMode') || 'dark';
        document.documentElement.classList.toggle('dark', mode === 'dark');
      })();
    </script>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <style>
      body {
        min-height: max(884px, 100dvh);
      }
    </style>
  </head>

  <body class="bg-background-light dark:bg-background-dark font-display">
    <div class="relative flex h-auto min-h-screen w-full flex-col" data-controller="image-modal" data-action="keydown.esc@document->image-modal#close">
      <%= yield %>

      <!-- Profile picture pop-out -->
      <div data-image-modal-target="dialog" data-action="click->image-modal#close" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 p-4">
        <button type="button" data-action="click->image-modal#close" aria-label="Close image" class="absolute top-4 right-4 flex h-10 w-10 items-center justify-center rounded-full bg-black/40 text-white text-xl">
          <i class="fas fa-times"></i>
        </button>
        <img data-image-modal-target="image" src="" alt="" class="max-h-full max-w-full rounded-lg object-contain">
      </div>
    </div>
  </body>
</html>
