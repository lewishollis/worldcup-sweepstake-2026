<%# app/views/games/audit.html.erb — admin-only device audit for the penalty game %>
<div class="max-w-lg mx-auto w-full">
  <header class="page-header">
    <div class="page-header-container">
      <h1 class="page-title">Penalty Game — Device Audit</h1>
    </div>
  </header>

  <main class="flex-1 px-4 md:px-6 pb-24 md:pb-8 flex flex-col gap-4 pt-4">
    <p class="text-sm text-text-secondary-light dark:text-text-secondary-dark">
      Devices (browsers) that have submitted scores for more than one friend. This is the
      tell-tale sign of one phone playing on several people's behalf. It identifies a browser,
      not a person — clearing site data or switching browser makes a fresh id.
    </p>

    <% if @suspicious_devices.empty? %>
      <div class="rounded-xl bg-green-500/10 border border-green-500/30 px-4 py-3 text-center">
        <p class="text-sm font-bold text-green-600 dark:text-green-400">✓ Nothing flagged</p>
        <p class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-1">
          No device has scored for more than one friend.
        </p>
      </div>
    <% else %>
      <div class="flex flex-col gap-3">
        <% @suspicious_devices.each do |device_id, friend_names| %>
          <div class="rounded-xl bg-amber-500/10 border border-amber-500/30 px-4 py-3">
            <p class="text-xs font-mono text-text-secondary-light dark:text-text-secondary-dark break-all">
              <%= device_id %>
            </p>
            <p class="text-sm font-bold text-amber-600 dark:text-amber-400 mt-1">
              Scored for <%= friend_names.size %> friends:
            </p>
            <p class="text-sm text-text-primary-light dark:text-text-primary-dark">
              <%= friend_names.join(", ") %>
            </p>
          </div>
        <% end %>
      </div>
    <% end %>
  </main>
</div>
