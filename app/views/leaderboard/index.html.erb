<div class="relative min-h-screen flex flex-col">
  <div class="max-w-7xl mx-auto w-full">
    <header class="page-header">
      <div class="page-header-container">
        <h1 class="page-title">Groups</h1>
      </div>
    </header>

    <main class="flex-grow px-4 md:px-6 lg:px-8 pb-24 md:pb-8 pt-6">
      <!-- Groups Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">
        <% @groups.each do |group| %>
          <article class="group-card">
            <!-- Group Header -->
            <div class="group-header">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <% if group.friend&.profile_picture_url.present? %>
                    <%= image_tag group.friend.profile_picture_url, alt: group.friend.name, class: "w-12 h-12 rounded-full object-cover cursor-pointer", data: { action: "click->image-modal#open", image_modal_src_param: group.friend.profile_picture_url, image_modal_alt_param: group.friend.name } %>
                  <% else %>
                    <div class="w-12 h-12 rounded-full bg-secondary/30 flex items-center justify-center">
                      <i class="fas fa-user text-xl text-secondary"></i>
                    </div>
                  <% end %>
                  <div>
                    <h3 class="group-title"><%= group.friend&.name || "No Friend Assigned" %></h3>
                    <p class="group-subtitle"><%= group.name %></p>
                  </div>
                </div>
                <div class="text-right">
                  <div class="group-points"><%= group.total_points %></div>
                  <div class="text-xs text-text-secondary-light dark:text-text-secondary-dark">points</div>
                </div>
              </div>
            </div>

            <!-- Teams List -->
            <div class="p-4 space-y-3">
              <% group.teams.each do |team| %>
                <div class="flex items-center gap-3 p-3 bg-background-light dark:bg-background-dark rounded-xl">
                  <% if team.flag_url.present? %>
                    <%= image_tag team.flag_url, alt: team.name, class: "h-8 w-8 rounded-full object-cover flex-shrink-0" %>
                  <% else %>
                    <div class="h-8 w-8 rounded-full bg-secondary/20 flex items-center justify-center flex-shrink-0">
                      <span class="text-xs font-bold text-secondary"><%= team.name[0] %></span>
                    </div>
                  <% end %>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2">
                      <p class="font-semibold text-text-primary-light dark:text-text-primary-dark truncate"><%= team.name %></p>
                      <div class="text-right flex-shrink-0">
                        <div class="text-lg font-bold text-text-primary-light dark:text-text-primary-dark"><%= team.progression_score %></div>
                        <div class="text-xs text-text-secondary-light dark:text-text-secondary-dark">pts</div>
                      </div>
                    </div>
                    <div class="flex flex-wrap gap-0.5 mt-0.5">
                      <%= render "shared/progression_ticks", team: team %>
                    </div>
                    <p class="text-xs text-text-secondary-light dark:text-text-secondary-dark mt-0.5">
                      <%= team.matches.where(status: 'PostEvent').count %> matches played
                    </p>
                  </div>
                </div>

                <!-- Match Results -->
                <% if team.matches.where(status: 'PostEvent').any? %>
                  <div class="ml-11 text-xs text-text-secondary-light dark:text-text-secondary-dark space-y-1">
                    <% team.matches.where(status: 'PostEvent').order(:start_time).each do |match| %>
                      <div class="flex items-center gap-2">
                        <i class="fas fa-circle text-[4px]"></i>
                        <span class="<%= match.stage != 'Group Stage' ? 'font-semibold text-accent-live' : '' %>">
                          <%= "[#{match.stage}]" unless match.stage == 'Group Stage' %>
                          vs <%= match.home_team_id == team.id ? match.away_team.name : match.home_team.name %>: <%= match.result_for(team) %>
                        </span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </main>
  </div>
</div>

<%= render 'layouts/bottom_nav' %>
